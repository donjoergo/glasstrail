# GlassTrail backend configuration example.
# Copy to `.env` (git-ignored) and fill in real values, then export the
# variables into your shell before running the smoke check, for example:
#   export $(grep -v '^#' .env | xargs)
# See docs/backend_setup.md for the full workflow.

# Supabase project to target. For the local CLI stack use the values printed
# by `supabase status`. Never commit real keys.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-local-anon-key

# Dedicated throwaway test users for tool/supabase_smoke_check.dart.
# Both users must already exist (sign up in the app or via Studio).
GT_SMOKE_USER_A_EMAIL=smoke-a@example.com
GT_SMOKE_USER_A_PASSWORD=change-me
GT_SMOKE_USER_B_EMAIL=smoke-b@example.com
GT_SMOKE_USER_B_PASSWORD=change-me

# Set to 1 to allow the smoke check to create and clean up test rows and
# tiny media uploads. Leave unset for read-only checks.
GT_SMOKE_ALLOW_WRITES=
